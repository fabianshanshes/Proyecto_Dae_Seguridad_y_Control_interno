# ####################################################################
# GITIGNORE GENERAL PARA PROYECTO (SERVER Y CLIENTE)
# ####################################################################

# --- DEPENDENCIAS (Packages) ---
# Ignora todas las carpetas node_modules tanto en el servidor como en el cliente
node_modules/
**/node_modules/

# --- ARCHIVOS DE CONFIGURACIÓN Y VARIABLES DE ENTORNO (Seguridad) ---
# Nunca subir credenciales, accesos a bases de datos o llaves secretas
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.*

# --- COMPILACIÓN Y PRODUCCIÓN (Vite / Frontend) ---
# Ignora las carpetas que se generan al compilar el proyecto de React
dist/
build/
.production/

# --- ARCHIVOS DEL SISTEMA OPERATIVO / IDEs ---
# Ignora archivos temporales de Windows, Mac o editores de código como VS Code
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- LOGS DE ERRORES ---
# Archivos de registro que generan npm o nodemon al fallar
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
client/package-lock.json

client/package.json

package-lock.json

server/package.json
